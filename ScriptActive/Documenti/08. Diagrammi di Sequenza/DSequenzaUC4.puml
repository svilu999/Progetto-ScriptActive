@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

title UC4 - Registrazione Risultati (con Pattern Information Expert e DAO)

actor "Cliente" as C
participant "StoricoAllenamentiView\n<<Boundary>>" as V
participant "StoricoAllenamentiController\n<<Controller>>" as Ctrl
participant "dao: SessioneDAO\n<<Interface>>" as DAO
participant "s: SessioneAllenamento\n<<Entity/Expert>>" as Entity
participant "DatabaseManager\n<<Singleton>>" as DBMan
database "db: scriptactive_db" as DB

autonumber

C -> V: seleziona "I miei allenamenti" (clickAccediStorico)
activate V

V -> Ctrl: gestisciAccessoSezione(cliente)
activate Ctrl

Ctrl -> V: mostraModuloInserimento()

Ctrl -> DAO: getStorico(cliente.getIdCliente())
activate DAO
DAO --> Ctrl: List<SessioneAllenamento>
deactivate DAO

Ctrl -> V: mostraStorico(storico)

C -> V: compila form e clicca "SALVA SESSIONE"
V -> Ctrl: salvaSessioneCompleta(data, eserciziInBozza, cliente)

Ctrl -> Entity **: new SessioneAllenamento(data, idCliente)

loop per ogni DatiFormPojo
    Ctrl -> Entity: aggiungiEsercizio(esercizio)
    activate Entity
    note right
      Pattern Information Expert:
      L'entità aggrega i propri componenti
      preservando l'incapsulamento.
    end note
    Entity --> Ctrl: (stato aggiornato)
    deactivate Entity
end

Ctrl -> DAO: salvaSessione(nuovaSessione)
activate DAO
note right
  Dependency Inversion (DAO):
  Il Controller usa l'astrazione. L'implementazione
  reale SQL è nascosta al livello superiore.
end note

DAO -> DBMan: getInstance().getConnection()
activate DBMan
note right: Pattern Singleton
DBMan --> DAO: Connection
deactivate DBMan

DAO -> DB: setAutoCommit(false)
activate DB
DAO -> DB: INSERT (Sessione) + executeBatch() (Esercizi)
DB --> DAO: commit()
deactivate DB

DAO --> Ctrl: true (salvataggio confermato)
deactivate DAO

Ctrl -> DAO: getStorico(cliente.getIdCliente())
activate DAO
note right: Postcondizione: Rinfresco dati
DAO --> Ctrl: List<SessioneAllenamento> aggiornata
deactivate DAO

Ctrl -> V: mostraStorico(storicoAggiornato)

Ctrl --> V: (ritorna il controllo)
deactivate Ctrl

V -> C: mostraMessaggio("Sessione salvata con successo!")
deactivate V

@enduml
@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

title UC4 - Flusso Alternativo 1 (Accesso con abbonamento BASE / Upgrade Premium)

actor "Cliente (Base)" as C
participant "StoricoAllenamentiView\n<<Boundary>>" as V
participant "StoricoAllenamentiController\n<<Controller>>" as Ctrl

autonumber

C -> V: seleziona "I miei allenamenti" (clickAccediStorico)
activate V

V -> Ctrl: gestisciAccessoSezione(cliente)
activate Ctrl

note right
  Regola di Dominio:
  Il Controller verifica se
  cliente.isPremium() == true.
end note

Ctrl --> V: throws UtenteNonPremiumException
deactivate Ctrl

note left
  Gestione delle Eccezioni:
  La Vista cattura l'eccezione
  nel blocco try-catch.
end note

V -> V: mostraBloccoUpgradePremium()
activate V
note right
  La View oscura il form e
  mostra la Call to Action.
end note
deactivate V

V --> C: mostra messaggio "Accesso Negato" e bottone "Sblocca Area Premium"
deactivate V

@enduml
@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

title UC6 - Autenticazione (Main Success Scenario)

actor "Attore\n(Cliente/PT/Direttore)" as U
participant "LoginView\n<<Boundary>>" as V
participant "LoginController\n<<Controller>>" as Ctrl
participant "dao: LoginDAO\n<<DAO>>" as DAO
database "db: Database" as DB
participant "utente: Utente\n<<Entity/Polymorphic>>" as Entity
participant "DashboardView\n<<Boundary>>" as DashV

autonumber

U -> V: 1-3. Inserisce credenziali e clicca "Accedi"
activate V

V -> Ctrl: effettuaLogin(email, password)
activate Ctrl

Ctrl -> DAO: 4. verificaCredenziali(email, pwd)
activate DAO

DAO -> DB: SELECT (Verifica sicura nel DB)
activate DB
DB --> DAO: ResultSet
deactivate DB

note right of DAO
  5-6. Conferma validità e
  identifica il ruolo
end note
DAO -> Entity **: istanziazione in base al ruolo

DAO --> Ctrl: restituisce l'entità 'utente'
deactivate DAO

Ctrl -> V: dispose() (Chiude il login)
deactivate V

note right of Ctrl
  7. Reindirizzamento
  tramite Double Dispatch
end note
Ctrl -> Entity: accediAreaRiservata(this)
activate Entity

Entity -> Ctrl: apriDashboardSpecifica(this)
deactivate Entity

Ctrl -> DashV **: new Dashboard...()
Ctrl -> DashV: impostaDati()
Ctrl -> DashV: setVisible(true)
activate DashV

DashV --> U: Mostra Area Riservata
deactivate DashV
deactivate Ctrl

@enduml
@startuml
skinparam style strictuml
skinparam sequenceMessageAlign center

title UC6 - Autenticazione (Gestione Flussi Alternativi e Rifiuti)

actor "Utente" as U
participant "LoginView\n<<Boundary>>" as V
participant "LoginController\n<<Controller>>" as Ctrl
participant "mDao: UtenteDAO\n<<DAO>>" as MDAO
participant "dao: LoginDAO\n<<DAO>>" as DAO

autonumber

U -> V: inserisce credenziali e clicca "Accedi"
activate V

V -> Ctrl: effettuaLogin(email, password)
activate Ctrl

alt Flusso Alt 3: Campi obbligatori mancanti
    note right of Ctrl: Controllo sintattico
    Ctrl -> V: mostraErrore("Inserisci sia email che password")
    V --> U: evidenzia campi e mostra errore
    
else Dati compilati
    Ctrl -> MDAO **: new UtenteDAOMySQL()
    Ctrl -> MDAO: tentaRinnovoSilenzioso(email)
    activate MDAO
    MDAO --> Ctrl: sbloccatoInAutomatico
    deactivate MDAO

    Ctrl -> DAO: verificaCredenziali(email, password)
    activate DAO
    DAO --> Ctrl: utente (o null se non trovato)
    deactivate DAO

    alt Flusso Alt 1: Credenziali Errate
        note right of Ctrl: utente == null
        Ctrl -> Ctrl: throw CredenzialiErrateException
        Ctrl -> V: mostraErrore("Email o password errate")
        V --> U: mostra errore e permette di riprovare
        
    else Flusso Alt 2: Account Disattivato/Sospeso
        note right of Ctrl: !utente.isAccountAbilitato()
        Ctrl -> Ctrl: throw AccountInattivoException
        Ctrl -> V: mostraErrore("Accesso negato: account sospeso")
        V --> U: mostra avviso ("Contattare la direzione")
        
    else Flusso Speciale: Abbonamento Scaduto
        note right of Ctrl: utente instanceof Cliente && !sbloccato
        Ctrl -> Ctrl: throw AbbonamentoScadutoException
        Ctrl -> V: mostraPopupRinnovo(email, msg)
        V --> U: propone upgrade/rinnovo
        
    
    end
end

deactivate Ctrl
deactivate V

@enduml